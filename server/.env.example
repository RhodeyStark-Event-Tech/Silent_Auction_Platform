# --- Server configuration ---
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed front-end origins (CORS).
CLIENT_ORIGIN=http://localhost:5173

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key — server only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin login (the only account that can access CRUD) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign admin session tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# --- Email (optional) ---
# If RESEND_API_KEY is unset, winner emails are logged to the console instead.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Ashleigh Auction <onboarding@resend.dev>

# --- Rate limiting / Upstash Redis ---
# Required in production (serverless) so rate limits are shared across
# instances. Locally, leave unset to use an in-memory limiter.
# Get these from upstash.com → your Redis database → "REST API".
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token

# Per-IP request ceilings (optional; sensible defaults below). Kept high
# because many bidders share one public IP on venue WiFi.
# RATE_LIMIT_BIDS_PER_MIN=300
# RATE_LIMIT_LOGIN_PER_15MIN=20

# --- Google Sheets export (optional) ---
# The admin "Export winners" button POSTs winner rows to a Google Apps Script
# web-app URL that writes them to a sheet. See docs/google-sheets-export.md.
# SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfy.../exec
# Shared secret — must match the SECRET constant in the Apps Script.
# SHEETS_WEBHOOK_SECRET=choose-a-long-random-string
